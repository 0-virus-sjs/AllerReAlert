# ============================================================
# AllerReAlert — 환경 변수 목록
# 실제 값은 Railway Variables / Vercel Environment Variables 에 등록.
# 이 파일에는 키 이름과 형식만 기재 — 실 값 절대 커밋 금지.
# PR 체크리스트: .env.example 에 새 키 추가 여부 확인 필수.
# ============================================================

# ── 서버 ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── 데이터베이스 (Supabase PostgreSQL) ───────────────────
# PgBouncer Pooled 연결 (포트 6543) — 일반 쿼리용
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:6543/postgres?pgbouncer=true

# Direct 연결 (포트 5432) — prisma migrate / introspect 전용
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── 암호화 (AES-256-GCM, 알레르기 컬럼 레벨 암호화) ────────
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-string

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# ── CORS ───────────────────────────────────────────────────
# Vercel 프리뷰 URL 또는 프로덕션 도메인
CLIENT_URL=http://localhost:3000

# ── Resend (이메일 발송) ────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Web Push / VAPID ───────────────────────────────────────
VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:admin@allerrealert.kr

# ── AI ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxx
OPENAI_API_KEY=sk-xxxx

# ── Supabase (Storage 백업 잡용) ────────────────────────────
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxx...  # Supabase → Settings → API → service_role key

# ── Sentry ─────────────────────────────────────────────────
SENTRY_DSN=https://xxxx@oXXXXX.ingest.sentry.io/XXXXXXX

# ── NEIS 급식 API (M6) ──────────────────────────────────────
NEIS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Frontend (Vite — VITE_ 접두사 필수) ────────────────────
VITE_API_URL=http://localhost:5000
VITE_SENTRY_DSN=https://xxxx@oXXXXX.ingest.sentry.io/XXXXXXX
VITE_VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
