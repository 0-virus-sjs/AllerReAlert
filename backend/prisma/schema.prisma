// Prisma 스키마 — Supabase PostgreSQL
// migrate:  npx prisma migrate dev --name <설명>
// studio:   npx prisma studio
// seed:     npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")  // PgBouncer Pooled (6543) — 일반 쿼리
  directUrl = env("DIRECT_URL")    // Direct (5432) — migrate / introspect 전용
}

// ── Enums ─────────────────────────────────────────────

enum OrgType {
  school
  company
  welfare
  military
  other
}

enum UserRole {
  student
  staff
  guardian
  nutritionist
  admin
}

// ── M1: T-010 Organization / User ────────────────────

model Organization {
  id             String   @id @default(cuid())
  name           String
  address        String?
  orgType        OrgType  @map("org_type")
  gradeStructure Json?    @map("grade_structure")
  mealTime       Json?    @map("meal_time")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("organizations")
}

model User {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  role         UserRole
  name         String
  email        String   @unique
  phone        String?
  groupInfo    Json?    @map("group_info")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, role])
  @@map("users")
}
