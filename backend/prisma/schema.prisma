// Prisma 스키마 — Supabase PostgreSQL
// migrate:  npx prisma migrate dev --name <설명>
// studio:   npx prisma studio
// seed:     npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")  // PgBouncer Pooled (6543) — 일반 쿼리
  directUrl = env("DIRECT_URL")    // Direct (5432) — migrate / introspect 전용
}

// ── Enums ─────────────────────────────────────────────

enum OrgType {
  school
  company
  welfare
  military
  other
}

enum UserRole {
  student
  staff
  guardian
  nutritionist
  admin
}

enum UserAllergenStatus {
  pending
  confirmed
  rejected
}

// ── M1: T-010 Organization / User ────────────────────

model Organization {
  id             String   @id @default(cuid())
  name           String
  address        String?
  orgType        OrgType  @map("org_type")
  gradeStructure Json?    @map("grade_structure")
  mealTime       Json?    @map("meal_time")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("organizations")
}

model User {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  role         UserRole
  name         String
  email        String   @unique
  phone        String?
  groupInfo    Json?    @map("group_info")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organization      Organization   @relation(fields: [orgId], references: [id])
  allergens         UserAllergen[] @relation("UserAllergens")
  approvedAllergies UserAllergen[] @relation("ApprovedAllergens")
  notifications     Notification[]

  @@index([orgId, role])
  @@map("users")
}

// ── M1: T-011 Allergen / UserAllergen ────────────────

model Allergen {
  id      String  @id @default(cuid())
  name    String
  code    Int     @unique
  iconUrl String? @map("icon_url")

  userAllergens UserAllergen[]

  @@map("allergens")
}

model UserAllergen {
  id         String             @id @default(cuid())
  userId     String             @map("user_id")
  allergenId String             @map("allergen_id")
  status     UserAllergenStatus @default(pending)
  approvedBy String?            @map("approved_by")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  user     User     @relation("UserAllergens", fields: [userId], references: [id])
  allergen Allergen @relation(fields: [allergenId], references: [id])
  approver User?    @relation("ApprovedAllergens", fields: [approvedBy], references: [id])

  @@map("user_allergens")
}

// ── M1: T-015 Notification ────────────────────────────

enum NotificationType {
  allergen_alert
  menu_change
  survey_invite
  survey_reminder
  approval_request
  approval_result
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  payload   Json?
  isRead    Boolean          @default(false) @map("is_read")
  sentAt    DateTime         @default(now()) @map("sent_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead, sentAt(sort: Desc)])
  @@map("notifications")
}
