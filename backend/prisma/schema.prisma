// Prisma 스키마 — Supabase PostgreSQL
// migrate:  npx prisma migrate dev --name <설명>
// studio:   npx prisma studio
// seed:     npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")  // PgBouncer Pooled (6543) — 일반 쿼리
  directUrl = env("DIRECT_URL")    // Direct (5432) — migrate / introspect 전용
}

// ── Enums ─────────────────────────────────────────────

enum OrgType {
  school
  company
  welfare
  military
  other
}

enum UserRole {
  student
  staff
  guardian
  nutritionist
  admin
}

enum Gender {
  male
  female
}

enum UserAllergenStatus {
  pending
  confirmed
  rejected
}

// ── M1: T-010 Organization / User ────────────────────

model Organization {
  id             String   @id @default(cuid())
  name           String
  address        String?
  orgType        OrgType  @map("org_type")
  gradeStructure Json?    @map("grade_structure")
  mealTime       Json?    @map("meal_time")
  // NEIS 급식 API 연동용 — orgType=school일 때만 의미. 그 외엔 null.
  atptCode       String?  @map("atpt_code")     // 시도교육청 코드 (예: J10 경기)
  schoolCode     String?  @map("school_code")   // NEIS 표준 학교 코드
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  users     User[]
  mealPlans MealPlan[]

  @@map("organizations")
}

model User {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  role         UserRole
  name         String
  email        String   @unique
  phone        String?
  groupInfo    Json?    @map("group_info")
  grade        Int?                                 // T-121 학생 학년 (1~12)
  classNo      String?  @map("class_no")            // T-121 학생 반 (문자 허용)
  studentCode  String?  @map("student_code")        // T-121 학생 학번
  gender       Gender?                              // T-126 성별 (학생 시 필수, 외 role은 null)
  linkCode                 String?   @unique @map("link_code")  // 학생 전용 연동코드 (보호자가 사용)
  passwordHash             String    @map("password_hash")
  refreshTokenHash         String?   @map("refresh_token_hash")
  consentedAt              DateTime? @map("consented_at")
  guardianConsentRequired  Boolean   @default(false) @map("guardian_consent_required")
  isActive                 Boolean   @default(true)  @map("is_active")   // T-091 관리자 활성/비활성
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  organization        Organization   @relation(fields: [orgId], references: [id])
  allergens           UserAllergen[] @relation("UserAllergens")
  approvedAllergies   UserAllergen[] @relation("ApprovedAllergens")
  notifications           Notification[]
  pushSubscriptions       PushSubscription[]
  auditLogs               AuditLog[]
  createdMealPlans        MealPlan[]          @relation("CreatedMealPlans")
  confirmedAlternatePlans AlternateMealPlan[] @relation("ConfirmedAlternatePlans")
  createdSurveys          Survey[]            @relation("CreatedSurveys")
  surveyResponses         SurveyResponse[]
  guardianLinks           GuardianStudent[]   @relation("GuardianLinks")
  studentLinks            GuardianStudent[]   @relation("StudentLinks")

  @@index([orgId, role])
  @@index([orgId, grade, classNo])
  @@map("users")
}

// ── M10: T-100 GuardianStudent (보호자-학생 연동) ────

model GuardianStudent {
  id         String   @id @default(cuid())
  guardianId String   @map("guardian_id")
  studentId  String   @map("student_id")
  createdAt  DateTime @default(now()) @map("created_at")

  guardian User @relation("GuardianLinks", fields: [guardianId], references: [id], onDelete: Cascade)
  student  User @relation("StudentLinks",  fields: [studentId],  references: [id], onDelete: Cascade)

  @@unique([guardianId, studentId])
  @@index([guardianId])
  @@index([studentId])
  @@map("guardian_students")
}

// ── M1: T-011 Allergen / UserAllergen ────────────────

model Allergen {
  id      String  @id @default(cuid())
  name    String
  code    Int     @unique
  iconUrl String? @map("icon_url")

  userAllergens       UserAllergen[]
  mealItemAllergens   MealItemAllergen[]
  alternateMealPlans  AlternateMealPlan[]
  keywords            AllergenKeyword[]

  @@map("allergens")
}

// 알레르기 키워드 사전 (자동 태깅 보강용)
// 출처:
//   - 'neis'   : NEIS 메뉴 이력에서 자동 추출
//   - 'manual' : 영양사/관리자 수동 추가
model AllergenKeyword {
  id          String   @id @default(cuid())
  allergenId  String   @map("allergen_id")
  keyword     String
  source      String   // 'neis' | 'manual'
  sampleCount Int      @default(1) @map("sample_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  allergen Allergen @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  @@unique([allergenId, keyword])
  @@index([source])
  @@map("allergen_keywords")
}

model UserAllergen {
  id                 String             @id @default(cuid())
  userId             String             @map("user_id")
  allergenId         String             @map("allergen_id")
  status             UserAllergenStatus @default(pending)
  approvedBy         String?            @map("approved_by")
  rejectionReason    String?            @map("rejection_reason")   // 반려 사유 (T-101)
  customAllergenName String?            @map("custom_allergen_name") // AES-256 암호화 저장
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user     User     @relation("UserAllergens", fields: [userId], references: [id])
  allergen Allergen @relation(fields: [allergenId], references: [id])
  approver User?    @relation("ApprovedAllergens", fields: [approvedBy], references: [id])

  @@map("user_allergens")
}

// ── M5: T-050 PushSubscription (웹 푸시 구독 저장) ────
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

// ── M1: T-015 Notification ────────────────────────────

enum NotificationType {
  allergen_alert
  menu_change
  survey_invite
  survey_reminder
  approval_request
  approval_result
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  payload   Json?
  isRead    Boolean          @default(false) @map("is_read")
  sentAt    DateTime         @default(now()) @map("sent_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead, sentAt(sort: Desc)])
  @@map("notifications")
}

// ── M1: T-016 AuditLog ───────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  targetType String   @map("target_type")
  targetId   String?  @map("target_id")
  ip         String?
  before     Json?
  after      Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

// ── M1: T-012 MealPlan / MealItem / MealItemAllergen ─

enum MealPlanStatus {
  draft
  published
}

enum MealItemCategory {
  rice
  soup
  side
  dessert
}

model MealPlan {
  id          String         @id @default(cuid())
  orgId       String         @map("org_id")
  date        DateTime       @db.Date
  status      MealPlanStatus @default(draft)
  publishedAt DateTime?      @map("published_at")
  scheduledAt DateTime?      @map("scheduled_at")  // T-032 예약 공개 시각
  createdBy   String         @map("created_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  organization   Organization       @relation(fields: [orgId], references: [id])
  createdByUser  User               @relation("CreatedMealPlans", fields: [createdBy], references: [id])
  items          MealItem[]
  alternatePlans AlternateMealPlan[]
  surveys        Survey[]

  @@index([orgId, date])
  @@map("meal_plans")
}

model MealItem {
  id         String          @id @default(cuid())
  mealPlanId String          @map("meal_plan_id")
  category   MealItemCategory
  name       String
  calories   Int?
  nutrients  Json?

  mealPlan       MealPlan           @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  allergens      MealItemAllergen[]
  alternateItems AlternateMealItem[]

  @@map("meal_items")
}

model MealItemAllergen {
  mealItemId   String  @map("meal_item_id")
  allergenId   String  @map("allergen_id")
  isAutoTagged Boolean @default(false) @map("is_auto_tagged")

  item     MealItem @relation(fields: [mealItemId], references: [id], onDelete: Cascade)
  allergen Allergen @relation(fields: [allergenId], references: [id])

  @@id([mealItemId, allergenId])
  @@map("meal_item_allergens")
}

// ── M1: T-013 AlternateMealPlan / AlternateMealItem ──

enum AlternatePlanStatus {
  draft
  confirmed
}

model AlternateMealPlan {
  id              String              @id @default(cuid())
  mealPlanId      String              @map("meal_plan_id")
  targetAllergenId String             @map("target_allergen_id")
  status          AlternatePlanStatus @default(draft)
  confirmedBy     String?             @map("confirmed_by")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  mealPlan       MealPlan    @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  targetAllergen Allergen    @relation(fields: [targetAllergenId], references: [id])
  confirmedByUser User?      @relation("ConfirmedAlternatePlans", fields: [confirmedBy], references: [id])
  items           AlternateMealItem[]

  @@map("alternate_meal_plans")
}

model AlternateMealItem {
  id             String  @id @default(cuid())
  altPlanId      String  @map("alt_plan_id")
  replacesItemId String  @map("replaces_item_id")
  name           String
  calories       Int?
  nutrients      Json?

  altPlan      AlternateMealPlan @relation(fields: [altPlanId], references: [id], onDelete: Cascade)
  replacesItem MealItem          @relation(fields: [replacesItemId], references: [id])

  @@map("alternate_meal_items")
}

// ── M1: T-014 Survey / SurveyResponse ────────────────

enum SurveyType {
  need_check
  menu_vote
}

enum SurveyStatus {
  open
  closed
}

model Survey {
  id          String       @id @default(cuid())
  mealPlanId  String       @map("meal_plan_id")
  type        SurveyType
  options     Json
  deadline    DateTime
  status      SurveyStatus @default(open)
  createdBy   String       @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  mealPlan      MealPlan         @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  createdByUser User             @relation("CreatedSurveys", fields: [createdBy], references: [id])
  responses     SurveyResponse[]

  @@map("surveys")
}

model SurveyResponse {
  id          String   @id @default(cuid())
  surveyId    String   @map("survey_id")
  userId      String   @map("user_id")
  response    Json
  votedItemId String?  @map("voted_item_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([surveyId, userId])
  @@map("survey_responses")
}

// ── AI 식단 생성 비동기 Job ─────────────────────────────

model MealGenerationJob {
  id            String   @id @default(cuid())
  orgId         String   @map("org_id")
  requestedBy   String   @map("requested_by")
  status        String   // queued | running | completed | failed
  input         Json
  result        Json?
  error         String?
  totalDays     Int?     @map("total_days")
  completedDays Int      @default(0) @map("completed_days")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([orgId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("meal_generation_jobs")
}
