# 서버 포트
PORT=5000

# 프론트엔드 도메인 (CORS 허용 대상)
CLIENT_URL=http://localhost:3000

# Supabase PostgreSQL 연결 문자열
# Supabase > Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# JWT 서명 키 (임의의 긴 문자열)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# AI 서비스
AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# 이메일 발송 (Resend)
RESEND_API_KEY=re_...

# Web Push 알림 (VAPID 키는 npx web-push generate-vapid-keys 로 생성)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# NEIS 교육정보 API 키
# https://open.neis.go.kr 에서 발급
NEIS_API_KEY=

# AES-256 컬럼 암호화 키 (64자리 hex)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Sentry 에러 추적 (T-115)
SENTRY_DSN=
APP_VERSION=

# Supabase 백업용 (T-116) — backupJob.ts
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# CORS 허용 도메인 (T-117 — 운영: Vercel 도메인)
CORS_ORIGIN=https://allerrealert.kr
