{
  "name": "allerealert-backend",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --files src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "extract-allergen-keywords": "ts-node scripts/extract-allergen-keywords.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.14.0",
    "@sentry/node": "^10.51.0",
    "@supabase/supabase-js": "^2.105.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "openai": "^6.36.0",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "resend": "^6.12.2",
    "web-push": "^3.6.7",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.14.0",
    "@types/node-cache": "^4.1.3",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
